{
  "name": "horizon-trader-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Horizon Trader Platform — komunitas trader dengan integrasi Telegram Bot dan website retro blogger",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "CFTC_VIEWER_ROOT=../docs/tools/cftc-export next dev frontend",
    "dev:bot": "tsx watch bot/src/index.ts",
    "build": "npm run build:frontend && npm run build:bot",
    "build:frontend": "CFTC_VIEWER_ROOT=../docs/tools/cftc-export next build frontend",
    "build:bot": "tsc -p bot/tsconfig.json",
    "start": "npm run start:frontend",
    "start:frontend": "CFTC_VIEWER_ROOT=../docs/tools/cftc-export next start frontend",
    "start:bot": "node bot/dist/bot/src/index.js",
    "db:seed": "node scripts/run-db-seeds.js",
    "db:seed:all": "bash scripts/seed-all.sh",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:property": "vitest --run --config vitest.property.config.ts",
    "review:install-browsers": "playwright install chromium",
    "review:visual": "playwright test tests/review/visual.spec.ts",
    "review:visual:update": "playwright test tests/review/visual.spec.ts --update-snapshots",
    "review:a11y": "playwright test tests/review/accessibility.spec.ts",
    "review:dom": "node scripts/review-dom-snapshot.mjs",
    "review:dom:update": "node scripts/review-dom-snapshot.mjs --update",
    "review:replay": "node scripts/review-session-replay.mjs",
    "review:mcp": "playwright-mcp --browser chromium --headless --isolated",
    "review:interaction": "playwright test tests/review/interaction.spec.ts",
    "review:percy": "percy exec -- playwright test tests/review/visual.percy.spec.ts",
    "review:all": "npm run review:a11y && npm run review:dom && npm run review:visual && npm run review:interaction",
    "storybook": "storybook dev -p 6006 -c frontend/.storybook",
    "build-storybook": "storybook build -c frontend/.storybook -o storybook-static",
    "review:chromatic": "chromatic --build-script-name=build-storybook --exit-zero-on-changes",
    "review:stagehand": "tsx tests/review/stagehand/explore-hertz.ts",
    "test:e2e": "playwright test tests/e2e",
    "analyze": "ANALYZE=true npm run build:frontend"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@next/bundle-analyzer": "^16.2.6",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.19.0",
    "grammy": "^1.25.0",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "2.16.0",
    "jiti": "^2.6.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "pg": "^8.12.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@browserbasehq/stagehand": "^3.4.0",
    "@percy/cli": "^1.31.13",
    "@percy/playwright": "^1.1.0",
    "@playwright/mcp": "^0.0.75",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/nextjs": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "chromatic": "^16.10.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "fast-check": "^3.19.0",
    "postcss": "^8.5.14",
    "rrweb": "^2.0.0-alpha.4",
    "shadcn": "^4.7.0",
    "storybook": "^10.4.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
