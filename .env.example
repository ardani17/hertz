# ============================================
# Horizon Trader Platform — Environment Variables
# Copy this file to .env and fill in the values
# ============================================
#
# Variabel bertanda [AUTO-CONSTRUCTED] tidak perlu diisi manual.
# Nilainya akan dikonstruksi otomatis oleh deploy script dari variabel lain.
#
# Variabel bertanda [REQUIRED] wajib diisi — deploy script akan gagal jika kosong.
# Variabel bertanda [DEFAULT: ...] opsional — akan menggunakan nilai default jika tidak diisi.


# ============================================
# Database (PostgreSQL)
# ============================================
# Konfigurasi koneksi ke PostgreSQL database container.

# Hostname service database di Docker network (default: db)
POSTGRES_HOST=db

# Port PostgreSQL di dalam container
POSTGRES_PORT=5432

# [REQUIRED] Nama database
POSTGRES_DB=horizon

# [REQUIRED] Username database
POSTGRES_USER=horizon_user

# [REQUIRED] Password database — ganti dengan password yang kuat
POSTGRES_PASSWORD=your_database_password_here

# [DEFAULT: ./data/postgres] Direktori host untuk menyimpan data PostgreSQL (bind mount).
# Data di direktori ini dapat di-backup langsung dari host tanpa perlu masuk ke container.
DB_DATA_DIR=./data/postgres

# [AUTO-CONSTRUCTED] Connection string database — dikonstruksi otomatis oleh deploy script
# dari POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_HOST, POSTGRES_PORT, dan POSTGRES_DB.
# Tidak perlu diisi manual.
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}


# ============================================
# Domain
# ============================================
# Konfigurasi domain. SSL ditangani oleh host reverse proxy (Cloudflare Origin Certificate).

# [REQUIRED] Domain utama platform (tanpa https://)
DOMAIN=yourdomain.com

# [AUTO-CONSTRUCTED] URL frontend — dikonstruksi otomatis oleh deploy script dari DOMAIN.
# Tidak perlu diisi manual. Nilai: https://${DOMAIN}
# FRONTEND_URL=https://${DOMAIN}

# [AUTO-CONSTRUCTED] Public site URL untuk Next.js — dikonstruksi otomatis oleh deploy script dari DOMAIN.
# Tidak perlu diisi manual. Nilai: https://${DOMAIN}
# NEXT_PUBLIC_SITE_URL=https://${DOMAIN}


# ============================================
# Telegram Bot
# ============================================
# Konfigurasi Telegram bot untuk integrasi platform.

# [REQUIRED] Token bot dari BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Nama bot (opsional, untuk display purposes)
TELEGRAM_BOT_NAME=your_bot_name_here

# Frontend: widget login Telegram (otomatis diisi dari TELEGRAM_BOT_NAME lewat next.config)
# NEXT_PUBLIC_TELEGRAM_BOT_NAME=your_bot_name_here

# Login dev localhost: salin frontend/.env.local.example → frontend/.env.local
# (gitignore, tidak ikut deploy produksi)

# ID grup Telegram (opsional, format: -100xxxxxxxxxx)
TELEGRAM_GROUP_ID=your_telegram_group_id_here

# ============================================
# HERTZ Platform
# ============================================
# HERTZ aktif default. Tidak ada mode sosial lama.
HERTZ_PLATFORM_ENABLED=true

# Endpoint verifikasi membership Telegram Horizon.
MEMBERSHIP_CHECK_URL=https://satpam.cloudnexify.com/api/membership/check

# Bearer token endpoint membership. Wajib untuk login Telegram member.
MEMBERSHIP_CHECK_TOKEN=your_membership_check_token_here

# Secret untuk HMAC session cookie member.
MEMBER_SESSION_SECRET=your_member_session_secret_here

# Upload gambar Direct Message. Phase awal menerima jpg, png, webp max 5MB.
DM_MAX_IMAGE_SIZE_MB=5
DM_MAX_IMAGES_PER_MESSAGE=4

# Group ID yang dipakai untuk verifikasi login member.
# Jika kosong, gunakan nilai TELEGRAM_GROUP_ID.
HORIZON_TELEGRAM_GROUP_ID=-1001916607651

# Firebase Cloud Messaging untuk push notification mobile Android/iOS.
# Isi dari Firebase Console > Project settings > Cloud Messaging > Server key.
# Jika dikosongkan, backend tetap mencatat notification_events dengan status skipped.
FCM_SERVER_KEY=your_fcm_server_key_here
FCM_ENDPOINT=https://fcm.googleapis.com/fcm/send

# Internal Docker-only GlobalData API URL.
# Jangan arahkan ke domain publik; Horizon frontend container mengakses service ini via horizon-net.
GLOBALDATA_API_URL=http://globaldata-api:3201

# [AUTO-CONSTRUCTED] Webhook URL — dikonstruksi otomatis oleh deploy script dari DOMAIN.
# Tidak perlu diisi manual. Nilai: https://${DOMAIN}/webhook/telegram
# TELEGRAM_WEBHOOK_URL=https://${DOMAIN}/webhook/telegram


# ============================================
# Cloudflare R2 Object Storage
# ============================================
# Konfigurasi Cloudflare R2 untuk penyimpanan media.

# Endpoint R2 (opsional, biasanya otomatis dari account ID)
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# Account ID Cloudflare (opsional)
R2_ACCOUNT_ID=your_r2_account_id_here

# [REQUIRED] Access key ID untuk R2
R2_ACCESS_KEY_ID=your_r2_access_key_id_here

# [REQUIRED] Secret access key untuk R2
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# [REQUIRED] Nama bucket R2
R2_BUCKET_NAME=horizon-media

# Public URL untuk akses media (custom domain R2)
R2_PUBLIC_URL=https://image.cloudnexify.com



# ============================================
# Challenge Tracker AI Review
# ============================================
# Server-side OpenAI-compatible AI provider for /tools/challenge-tracker.
# Do not expose these values to the browser. The UI only uses personas/settings;
# provider credentials are controlled by admin through .env.
CHALLENGE_AI_PROVIDER=plexus
CHALLENGE_AI_BASE_URL=https://your-openai-compatible-provider.example.com/v1
CHALLENGE_AI_API_KEY=your_challenge_ai_api_key_here
CHALLENGE_AI_MODEL=glm-5-turbo
CHALLENGE_AI_TIMEOUT_MS=45000

# ============================================
# Admin Credentials
# ============================================
# Credential untuk initial seed admin user.
# Ganti dengan nilai yang aman sebelum deployment.

# [REQUIRED] Username admin
ADMIN_USERNAME=admin

# [REQUIRED] Password admin — ganti dengan password yang kuat
ADMIN_PASSWORD=your_admin_password_here


# ============================================
# Service Ports
# ============================================
# Port untuk masing-masing service. Nilai default sudah sesuai untuk kebanyakan setup.
# Ubah hanya jika ada konflik port di server Anda.

# [DEFAULT: 3000] Port internal frontend (Next.js)
FRONTEND_PORT=3000

# [DEFAULT: 3888] Port host untuk frontend (diakses oleh aaPanel Nginx)
FRONTEND_HOST_PORT=3888

# [DEFAULT: 4000] Port internal bot (Express)
BOT_PORT=4000

# [DEFAULT: 4888] Port host untuk bot (diakses oleh aaPanel Nginx)
BOT_HOST_PORT=4888


# ============================================
# Application
# ============================================
# Konfigurasi umum aplikasi.

# [DEFAULT: production] Environment mode (production / development)
NODE_ENV=production
