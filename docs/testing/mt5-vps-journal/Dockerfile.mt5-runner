FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    DISPLAY=:99 \
    WINEPREFIX=/wine-prefix \
    WINEDEBUG=-all \
    MT5_TERMINAL_EXE=/mt5/terminal64.exe \
    EXPORT_DIR=/exports \
    MT5_RUN_MODE=terminal

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      procps \
      xvfb \
      xauth \
      x11-utils \
      wine64 \
      fonts-liberation \
      fonts-dejavu-core \
      tini \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --system --create-home --home-dir /home/mt5 --shell /usr/sbin/nologin mt5 \
    && mkdir -p /wine-prefix /mt5 /exports /logs \
    && chown -R mt5:mt5 /wine-prefix /mt5 /exports /logs /home/mt5

COPY --chown=mt5:mt5 scripts/mt5_runner_entrypoint.sh /usr/local/bin/mt5_runner_entrypoint.sh
RUN chmod +x /usr/local/bin/mt5_runner_entrypoint.sh

USER mt5
WORKDIR /home/mt5

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD pgrep -f Xvfb >/dev/null && { [ "$MT5_RUN_MODE" = "mock" ] || pgrep -f 'terminal64.exe|terminal.exe|wine' >/dev/null; }

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/mt5_runner_entrypoint.sh"]
