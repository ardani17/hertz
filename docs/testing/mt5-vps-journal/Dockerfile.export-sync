FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    EXPORT_DIR=/exports \
    API_BASE_URL=http://journal-api:8088 \
    SYNC_INTERVAL_SECONDS=10 \
    SYNC_LOGIN=308881

WORKDIR /app

RUN addgroup --system app && adduser --system --ingroup app app \
    && mkdir -p /exports /logs \
    && chown -R app:app /exports /logs /app

COPY --chown=app:app scripts/export_sync_watcher.py /app/export_sync_watcher.py

USER app

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "import json,os,time; p=os.environ.get('SYNC_HEALTH_FILE','/logs/export-sync-health.json'); d=json.load(open(p)); raise SystemExit(0 if d.get('last_ok_ts') and time.time()-float(d['last_ok_ts']) < 120 else 1)"

CMD ["python", "/app/export_sync_watcher.py"]
