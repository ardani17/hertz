[Unit]
Description=MT5 Trading Journal Dashboard API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mt5journal
Group=mt5journal
WorkingDirectory=/opt/mt5-vps-journal
EnvironmentFile=/etc/mt5-journal.env
ExecStart=/usr/bin/python3 /opt/mt5-vps-journal/server.py
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/mt5-vps-journal/data /opt/mt5-vps-journal/public /opt/mt5-vps-journal/logs

[Install]
WantedBy=multi-user.target
