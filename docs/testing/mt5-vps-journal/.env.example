# Copy to .env and change values before production.
APP_HOST=127.0.0.1
APP_PORT=8088
# Required for POST /api/import/* . Generate: openssl rand -hex 32
INGEST_TOKEN=change-me-long-random-token
# Optional Basic Auth for browser access. Leave empty in local test only.
DASHBOARD_USER=arr
DASHBOARD_PASSWORD=change-me-dashboard-password
# Used by scripts/headless_mt5_service.sh and systemd templates.
WINEPREFIX=/opt/mt5-journal/wine-prefix
DISPLAY=:99
